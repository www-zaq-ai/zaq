<!DOCTYPE html>
<html lang="en" data-color-mode>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta favicon="icon" href={~p"/favicon.ico"} />
    <.live_title default="ZAQ" suffix=" · Back Office">
      {assigns[:page_title]}
    </.live_title>
    <.figma_capture_script enabled={assigns[:figma_capture_enabled] || false} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const root = document.documentElement;

        /* ZAQ foundations + semantics use [data-zaq-theme="dark"]; DaisyUI / Phoenix use data-theme. */
        const syncZaqTheme = (theme) => {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const zaqDark = theme === "dark" || (theme === "system" && prefersDark);
          if (zaqDark) {
            root.setAttribute("data-zaq-theme", "dark");
          } else {
            root.removeAttribute("data-zaq-theme");
          }
        };

        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            root.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            root.setAttribute("data-theme", theme);
          }
          syncZaqTheme(theme);
        };

        if (!root.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        } else {
          const attr = root.getAttribute("data-theme");
          const theme = attr === "light" || attr === "dark" ? attr : "system";
          syncZaqTheme(theme);
        }

        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme") setTheme(e.newValue || "system");
        });

        window.addEventListener("phx:set-theme", (e) => {
          setTheme(e.target?.dataset?.phxTheme || "system");
        });

        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
          if (!localStorage.getItem("phx:theme")) syncZaqTheme("system");
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
