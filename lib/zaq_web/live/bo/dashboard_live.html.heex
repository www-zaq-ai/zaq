<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title="Dashboard"
  current_path={@current_path}
  features_version={@features_version}
>
  <!-- Portal consent retry banner (only when portal is reachable) -->
  <div
    :if={@show_portal_banner}
    class="mb-6 flex items-center justify-between gap-4 rounded-xl border border-cyan-200 bg-cyan-50 px-5 py-4"
  >
    <div class="flex items-center gap-3 min-w-0">
      <svg
        class="w-5 h-5 text-cyan-600 shrink-0"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        viewBox="0 0 24 24"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      <p class="font-mono text-[0.78rem] text-slate-600 truncate">
        {@portal_metadata["metadata"]["banner_text"]}
      </p>
    </div>
    <button
      phx-click="show_portal_consent"
      class="shrink-0 rounded-lg bg-cyan-600 px-4 py-1.5 font-mono text-[0.75rem] font-semibold text-white hover:bg-cyan-700 transition-colors"
    >
      Activate
    </button>
  </div>
  
<!-- Offline notice (airgapped / portal unreachable) -->
  <div
    :if={not @portal_reachable}
    class="mb-6 flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-5 py-4"
  >
    <svg
      class="w-4 h-4 text-slate-400 shrink-0"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      viewBox="0 0 24 24"
    >
      <path d="M18.364 5.636a9 9 0 1 1-12.728 0" /><path d="M12 2v7" />
    </svg>
    <p class="font-mono text-[0.75rem] text-slate-500">
      ZAQ portal is not reachable in this environment — portal features are unavailable.
    </p>
  </div>

  <ZaqWeb.Components.PortalConsentModal.portal_consent_modal
    :if={@portal_reachable}
    show={@show_portal_consent_modal}
    on_decline="close_portal_consent_modal"
    title={@portal_metadata["metadata"]["title"]}
    body={@portal_metadata["metadata"]["body"]}
    accept_label={@portal_metadata["metadata"]["accept_label"]}
    decline_label={@portal_metadata["metadata"]["decline_label"]}
    subtitle={@portal_metadata["metadata"]["subtitle"]}
    footnote={@portal_metadata["metadata"]["footnote"]}
    require_email={@require_portal_email}
    email={@portal_consent_email}
    on_email_change="portal_consent_email_change"
    error={@portal_provision_error}
  />

  <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
    <div :for={metric <- @metric_cards} class="space-y-2">
      <.link
        id={metric.id}
        navigate={metric.runtime.href || "/bo/dashboard"}
        class="group block"
      >
        <ZaqWeb.Components.BOTelemetryComponents.metric_card
          id={metric.id <> "-card"}
          card={metric}
        />
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-documents-ingested"}
        id="dashboard-knowledge-base-metrics-link"
        navigate={~p"/bo/dashboard/knowledge-base-metrics"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View Knowledge base metrics <span class="text-[0.8rem]">-&gt;</span>
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-llm-api-calls"}
        id="dashboard-llm-performance-link"
        navigate={~p"/bo/dashboard/llm-performance"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View LLM performance <span class="text-[0.8rem]">-&gt;</span>
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-qa-response-time"}
        id="dashboard-conversations-metrics-link"
        navigate={~p"/bo/dashboard/conversations-metrics"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View Conversations metrics <span class="text-[0.8rem]">-&gt;</span>
      </.link>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-6">
    <!-- Services -->
    <div class="col-span-2">
      <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider mb-3">Services</p>
      <div class="bg-white rounded-xl border border-black/10 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-black/10">
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Service
              </th>
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Description
              </th>
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Node
              </th>
              <th class="text-right font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Status
              </th>
            </tr>
          </thead>
          <tbody>
            <tr
              :for={svc <- @services}
              class="border-b border-black/5 last:border-0 hover:bg-black/[0.02]"
            >
              <td class="font-mono text-sm font-bold text-black px-6 py-4">{svc.name}</td>
              <td class="font-mono text-[0.75rem] text-black/50 px-6 py-4">{svc.description}</td>
              <td class="font-mono text-[0.7rem] text-black/40 px-6 py-4">
                <%= if svc.node do %>
                  {svc.node}
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <span
                  :if={svc.active}
                  class="font-mono text-[0.7rem] px-2 py-1 rounded bg-emerald-100 text-emerald-700"
                >
                  Running
                </span>
                <span
                  :if={!svc.active}
                  class="font-mono text-[0.7rem] px-2 py-1 rounded bg-black/5 text-black/30"
                >
                  Disabled
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    
<!-- Add-ons Card -->
    <div>
      <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider mb-3">Add-ons</p>
      <%= if @addon_data do %>
        <div class="bg-white rounded-xl border border-black/10 p-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-100 grid place-items-center">
              <svg
                class="w-[18px] h-[18px] text-emerald-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="10" />
              </svg>
            </div>
            <div>
              <p class="font-mono text-sm font-bold text-black">
                {@addon_data["company_name"]}
              </p>
              <p class="font-mono text-[0.65rem] text-black/40">{@addon_data["license_key"]}</p>
            </div>
          </div>
          <div class="border-t border-black/5 pt-3 space-y-2">
            <div class="flex justify-between">
              <p class="font-mono text-[0.7rem] text-black/40">Features</p>
              <p class="font-mono text-[0.7rem] text-black">
                {length(@addon_data["features"])}
              </p>
            </div>
            <div class="flex justify-between">
              <p class="font-mono text-[0.7rem] text-black/40">Days Left</p>
              <p class={[
                "font-mono text-[0.7rem] font-bold",
                cond do
                  @days_left == nil -> "text-black"
                  @days_left <= 30 -> "text-red-600"
                  @days_left <= 90 -> "text-amber-600"
                  true -> "text-emerald-600"
                end
              ]}>
                {@days_left}
              </p>
            </div>
          </div>
          <.link
            href={~p"/bo/addons"}
            class="block text-center font-mono text-[0.75rem] text-[#03b6d4] hover:underline"
          >
            View Details →
          </.link>
        </div>
      <% else %>
        <div class="bg-white rounded-xl border border-dashed border-black/15 p-5 text-center">
          <div class="w-9 h-9 rounded-lg bg-black/5 grid place-items-center mx-auto mb-3">
            <svg
              class="w-[18px] h-[18px] text-black/30"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </div>
          <p class="font-mono text-sm font-bold text-black mb-1">No Add-ons</p>
          <p class="font-mono text-[0.7rem] text-black/40 mb-3">Running in basic mode</p>
          <.link
            href={~p"/bo/addons"}
            class="inline-block font-mono text-[0.75rem] font-bold px-4 py-2 rounded-lg bg-[#03b6d4] text-white hover:bg-[#03b6d4]/90 transition-colors"
          >
            Learn More
          </.link>
        </div>
      <% end %>
    </div>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
