<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title="Dashboard"
  current_path={@current_path}
  features_version={@features_version}
>
  <%!-- <div class="mb-4 flex flex-col gap-3 rounded-xl border border-black/10 bg-white p-4 md:flex-row md:items-center md:justify-between">
    <p class="font-mono text-[0.7rem] text-black/45">
      Review telemetry widgets and interactions before wiring production data.
    </p>
    <.link
      id="dashboard-telemetry-preview-link"
      navigate={~p"/bo/dashboard/telemetry-preview"}
      class="inline-flex items-center gap-2 self-start rounded-lg border border-[#03b6d4]/30 bg-[#03b6d4]/10 px-3 py-1.5 font-mono text-[0.72rem] font-bold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/20"
    >
      Open telemetry preview <span class="text-[0.8rem]">-&gt;</span>
    </.link>
  </div> --%>

  <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div :for={metric <- @metric_cards} class="space-y-2">
      <.link
        id={metric.id}
        navigate={metric.runtime.href || "/bo/dashboard"}
        class="group block"
      >
        <ZaqWeb.Components.BOTelemetryComponents.metric_card
          id={metric.id <> "-card"}
          card={metric}
        />
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-documents-ingested"}
        id="dashboard-knowledge-base-metrics-link"
        navigate={~p"/bo/dashboard/knowledge-base-metrics"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View Knowledge base metrics <span class="text-[0.8rem]">-&gt;</span>
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-llm-api-calls"}
        id="dashboard-llm-performance-link"
        navigate={~p"/bo/dashboard/llm-performance"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View LLM performance <span class="text-[0.8rem]">-&gt;</span>
      </.link>

      <.link
        :if={metric.id == "dashboard-metric-qa-response-time"}
        id="dashboard-conversations-metrics-link"
        navigate={~p"/bo/dashboard/conversations-metrics"}
        class="inline-flex items-center gap-2 rounded-lg border border-[#03b6d4]/25 bg-white px-3 py-1.5 font-mono text-[0.68rem] font-semibold text-[#03b6d4] transition-colors hover:bg-[#03b6d4]/10"
      >
        View Conversations metrics <span class="text-[0.8rem]">-&gt;</span>
      </.link>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-6">
    <!-- Services -->
    <div class="col-span-2">
      <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider mb-3">Services</p>
      <div class="bg-white rounded-xl border border-black/10 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-black/10">
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Service
              </th>
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Description
              </th>
              <th class="text-left font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Node
              </th>
              <th class="text-right font-mono text-[0.7rem] text-black/40 uppercase tracking-wider px-6 py-3">
                Status
              </th>
            </tr>
          </thead>
          <tbody>
            <tr
              :for={svc <- @services}
              class="border-b border-black/5 last:border-0 hover:bg-black/[0.02]"
            >
              <td class="font-mono text-sm font-bold text-black px-6 py-4">{svc.name}</td>
              <td class="font-mono text-[0.75rem] text-black/50 px-6 py-4">{svc.description}</td>
              <td class="font-mono text-[0.7rem] text-black/40 px-6 py-4">
                <%= if svc.node do %>
                  {svc.node}
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <span
                  :if={svc.active}
                  class="font-mono text-[0.7rem] px-2 py-1 rounded bg-emerald-100 text-emerald-700"
                >
                  Running
                </span>
                <span
                  :if={!svc.active}
                  class="font-mono text-[0.7rem] px-2 py-1 rounded bg-black/5 text-black/30"
                >
                  Disabled
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    
<!-- License Card -->
    <div>
      <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider mb-3">License</p>
      <%= if @license_data do %>
        <div class="bg-white rounded-xl border border-black/10 p-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-100 grid place-items-center">
              <svg
                class="w-[18px] h-[18px] text-emerald-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="10" />
              </svg>
            </div>
            <div>
              <p class="font-mono text-sm font-bold text-black">
                {@license_data["company_name"]}
              </p>
              <p class="font-mono text-[0.65rem] text-black/40">{@license_data["license_key"]}</p>
            </div>
          </div>
          <div class="border-t border-black/5 pt-3 space-y-2">
            <div class="flex justify-between">
              <p class="font-mono text-[0.7rem] text-black/40">Features</p>
              <p class="font-mono text-[0.7rem] text-black">
                {length(@license_data["features"])}
              </p>
            </div>
            <div class="flex justify-between">
              <p class="font-mono text-[0.7rem] text-black/40">Days Left</p>
              <p class={[
                "font-mono text-[0.7rem] font-bold",
                cond do
                  @days_left == nil -> "text-black"
                  @days_left <= 30 -> "text-red-600"
                  @days_left <= 90 -> "text-amber-600"
                  true -> "text-emerald-600"
                end
              ]}>
                {@days_left}
              </p>
            </div>
          </div>
          <.link
            href={~p"/bo/license"}
            class="block text-center font-mono text-[0.75rem] text-[#03b6d4] hover:underline"
          >
            View Details →
          </.link>
        </div>
      <% else %>
        <div class="bg-white rounded-xl border border-dashed border-black/15 p-5 text-center">
          <div class="w-9 h-9 rounded-lg bg-black/5 grid place-items-center mx-auto mb-3">
            <svg
              class="w-[18px] h-[18px] text-black/30"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </div>
          <p class="font-mono text-sm font-bold text-black mb-1">No License</p>
          <p class="font-mono text-[0.7rem] text-black/40 mb-3">Running in basic mode</p>
          <.link
            href={~p"/bo/license"}
            class="inline-block font-mono text-[0.75rem] font-bold px-4 py-2 rounded-lg bg-[#03b6d4] text-white hover:bg-[#03b6d4]/90 transition-colors"
          >
            Learn More
          </.link>
        </div>
      <% end %>
    </div>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
