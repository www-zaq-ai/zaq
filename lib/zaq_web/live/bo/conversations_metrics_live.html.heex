<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  page_title="Conversations Metrics"
  current_path={@current_path}
>
  <div id="conversations-metrics-page" class="space-y-6">
    <section class="rounded-xl border border-black/10 bg-white p-4">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div>
          <p class="font-mono text-[0.72rem] uppercase tracking-wider text-black/45">
            Conversations telemetry
          </p>
          <p class="font-mono text-[0.68rem] text-black/40">
            Live conversations trends from rollup telemetry buckets
          </p>
        </div>
        <.link
          id="conversations-metrics-back-to-dashboard"
          navigate={~p"/bo/dashboard"}
          class="font-mono text-[0.72rem] text-[#03b6d4] hover:underline"
        >
          Back to dashboard
        </.link>
      </div>

      <div class="flex flex-wrap gap-2">
        <button
          :for={range <- @ranges}
          id={"conversations-metrics-range-#{range}"}
          phx-click="set_range"
          phx-value-range={range}
          data-active={to_string(@range == range)}
          class={[
            "font-mono text-[0.7rem] px-2.5 py-1.5 rounded border transition-colors",
            if(@range == range,
              do: "bg-[#03b6d4] text-white border-[#03b6d4]",
              else: "bg-white text-black/55 border-black/15 hover:bg-black/[0.03]"
            )
          ]}
        >
          {range}
        </button>
      </div>
      <div class="hidden">
        <span id="conversations-metrics-selected-range">{@range}</span>
      </div>
    </section>

    <section class="grid grid-cols-1 gap-4 xl:grid-cols-3">
      <ZaqWeb.Components.BOTelemetryComponents.time_series_chart
        id="conversations-metrics-questions-asked-chart"
        title="Questions asked (cumulative)"
        points={@questions_asked_points}
      />

      <ZaqWeb.Components.BOTelemetryComponents.donut_chart
        id="conversations-metrics-questions-per-channel-chart"
        title="Questions per channel"
        segments={get_in(@questions_per_channel_chart, [:summary, :segments]) || []}
      />

      <ZaqWeb.Components.BOTelemetryComponents.time_series_chart
        id="conversations-metrics-no-answer-rate-chart"
        title="No-answer rate"
        points={@no_answer_rate_points}
        benchmark_points={@no_answer_threshold_points}
        secondary_color="#6b7280"
      />
    </section>

    <section class="grid grid-cols-1 gap-4 xl:grid-cols-2">
      <ZaqWeb.Components.BOTelemetryComponents.time_series_chart
        id="conversations-metrics-average-response-time-chart"
        title="Average response time"
        points={@average_response_time_points}
        benchmark_points={@response_sla_points}
        secondary_color="#6b7280"
      />

            <ZaqWeb.Components.BOTelemetryComponents.radar_chart
        id="conversations-metrics-confidence-distribution-chart"
        title="Answer confidence distribution"
        axes={get_in(@answer_confidence_distribution_chart, [:summary, :axes]) || []}
      />


    </section>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
