<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title={@conversation.title || "Conversation"}
  current_path={@current_path}
  features_version={@features_version}
>
  <style>
    @keyframes slide-in-right {
      from { opacity: 0; transform: translateX(12px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes slide-in-left {
      from { opacity: 0; transform: translateX(-12px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .animate-slide-in-right { animation: slide-in-right 0.2s ease-out; }
    .animate-slide-in-left  { animation: slide-in-left  0.2s ease-out; }

    .msg-actions {
      opacity: 0;
      transition: opacity 0.15s ease;
    }
    .group:hover .msg-actions { opacity: 1; }
  </style>

  <%!-- Header bar --%>
  <div class="flex items-start justify-between mb-5">
    <div>
      <.link
        navigate={~p"/bo/history"}
        class="font-mono text-[0.75rem] text-black/40 hover:text-[#03b6d4] transition-colors"
      >
        ← History
      </.link>
      <div class="flex items-center gap-2 mt-2">
        <span class="font-mono text-[0.7rem] px-2 py-0.5 rounded bg-black/5 text-black/50">
          {String.capitalize(@conversation.channel_type)}
        </span>
        <span
          :if={@conversation.status == "active"}
          class="font-mono text-[0.7rem] px-2 py-0.5 rounded bg-emerald-100 text-emerald-700"
        >
          active
        </span>
        <span
          :if={@conversation.status == "archived"}
          class="font-mono text-[0.7rem] px-2 py-0.5 rounded bg-black/5 text-black/40"
        >
          archived
        </span>
      </div>
    </div>
    <button
      phx-click="open_share_dialog"
      class="font-mono text-sm font-bold px-4 py-2 rounded-lg bg-[#03b6d4] text-white hover:bg-[#03b6d4]/90 transition-colors"
    >
      Share
    </button>
  </div>

  <%!-- Chat thread --%>
  <div class="flex gap-6 items-start">
    <div
      class="-mx-8 flex-1 rounded-xl overflow-hidden"
      style="background-color: #f7f6f3;"
    >
      <div class="max-w-3xl mx-auto px-6 py-6 space-y-5">
        <%= for item <- inject_date_separators(@messages, :inserted_at) do %>
          <%= if Map.get(item, :type) == :date_separator do %>
            <div class="flex items-center gap-3 my-1">
              <div class="flex-1 h-px" style="background:#e8e6e1;"></div>
              <span
                class="font-mono text-[0.62rem] uppercase tracking-widest"
                style="color:#b8b5ae;"
              >
                {format_date(item.date)}
              </span>
              <div class="flex-1 h-px" style="background:#e8e6e1;"></div>
            </div>
          <% else %>
            <%= if item.role == "user" do %>
              <ZaqWeb.Components.ChatMessage.user_bubble
                content={item.content}
                timestamp={item.inserted_at}
              />
            <% else %>
              <% feedback = infer_feedback_from_ratings(item.ratings || []) %>
              <ZaqWeb.Components.ChatMessage.assistant_bubble
                content={item.content}
                timestamp={item.inserted_at}
                confidence={item.confidence_score}
                sources={item.sources || []}
                source_click_event="open_preview_modal"
              >
                <:actions>
                  <ZaqWeb.Components.ChatMessage.tool_calls_info_button
                    tool_calls={Map.get(item.metadata || %{}, "tool_calls", [])}
                    message_id={item.id}
                    open_event="open_tool_calls_modal"
                  />
                  <ZaqWeb.Components.ChatMessage.copy_logs_button
                    steps={Map.get(item.metadata || %{}, "steps", [])}
                    message_id={item.id}
                  />
                  <ZaqWeb.Components.ChatMessage.copy_action_button text={item.content || ""} />
                  <ZaqWeb.Components.ChatMessage.feedback_positive_button
                    message_id={item.id}
                    feedback={feedback}
                  />
                  <ZaqWeb.Components.ChatMessage.feedback_negative_button
                    message_id={item.id}
                    feedback={feedback}
                  />
                </:actions>
              </ZaqWeb.Components.ChatMessage.assistant_bubble>
              <%!-- Feedback comment (from chat negative feedback) --%>
              <div
                :if={
                  List.first(item.ratings || []) &&
                    List.first(item.ratings || []).comment not in [nil, ""]
                }
                class="ml-10 -mt-2 px-3 py-2 rounded-lg border"
                style="background:#fff7ed; border-color:#fed7aa;"
              >
                <p class="font-mono text-[0.68rem]" style="color:#c2410c;">
                  <span class="font-bold">Feedback:</span> {List.first(item.ratings || []).comment}
                </p>
              </div>
            <% end %>
          <% end %>
        <% end %>

        <div :if={@messages == []} class="py-16 text-center">
          <p class="font-mono text-sm" style="color:#b8b5ae;">No messages yet.</p>
        </div>
      </div>
    </div>

    <%!-- Shares panel --%>
    <div :if={@shares != []} class="w-64 flex-shrink-0">
      <div class="bg-white rounded-xl border border-black/10 overflow-hidden">
        <div class="px-5 py-3 border-b border-black/10">
          <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider">
            Active Shares
          </p>
        </div>
        <ul class="divide-y divide-black/5">
          <li
            :for={share <- @shares}
            id={"share-#{share.id}"}
            class="px-4 py-3 space-y-1.5"
          >
            <div class="flex items-center gap-1.5">
              <span class="font-mono text-[0.62rem] px-1.5 py-0.5 rounded bg-black/5 text-black/40">
                {share.permission}
              </span>
              <button
                phx-click="revoke_share"
                phx-value-id={share.id}
                data-confirm="Revoke this share?"
                class="font-mono text-[0.62rem] text-red-500 hover:underline ml-auto"
              >
                Revoke
              </button>
            </div>
            <div class="flex items-center gap-1">
              <input
                type="text"
                readonly
                value={url(~p"/s/#{share.share_token}")}
                class="font-mono text-[0.6rem] text-black/50 bg-black/[0.03] border border-black/10 rounded px-1.5 py-1 w-full min-w-0 select-all focus:outline-none"
              />
              <button
                id={"copy-#{share.id}"}
                data-share-url={url(~p"/s/#{share.share_token}")}
                phx-hook="CopyToClipboard"
                class="flex-shrink-0 font-mono text-[0.62rem] px-2 py-1 rounded border border-black/10 text-black/50 hover:bg-black/5 transition-colors"
              >
                Copy
              </button>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <%!-- Share dialog --%>
  <ZaqWeb.Components.FilePreviewModal.modal
    :if={@preview}
    preview={@preview}
    cancel_event="close_preview_modal"
  />

  <ZaqWeb.Components.ChatMessage.tool_calls_popin
    visible={is_binary(@tool_calls_modal_for)}
    message_id={@tool_calls_modal_for}
    tool_calls={@tool_calls_modal_entries}
    expanded_ids={@expanded_tool_call_ids}
    close_event="close_tool_calls_modal"
    toggle_event="toggle_tool_call_details"
  />

  <div
    :if={@show_feedback_modal}
    id="feedback-modal"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
    phx-click="close_feedback_modal"
  >
    <div
      class="w-full max-w-md rounded-2xl border border-[#ece8e2] bg-white p-5 shadow-xl"
      phx-click="noop"
    >
      <div class="mb-4 flex items-center justify-between">
        <h3 class="font-mono text-[0.78rem] font-semibold uppercase tracking-wide text-[#2c2b28]">
          What went wrong?
        </h3>
        <button
          type="button"
          phx-click="close_feedback_modal"
          class="rounded-md p-1 text-[#b8b5ae] transition-colors hover:bg-[#f4f2ef]"
        >
          <span class="sr-only">Close</span>
          <.icon name="hero-x-mark" class="h-4 w-4" />
        </button>
      </div>

      <div class="space-y-3">
        <div class="space-y-2">
          <%= for reason <- [
            "Not accurate",
            "Missing details",
            "Not relevant",
            "Poor formatting",
            "Other"
          ] do %>
            <button
              type="button"
              phx-click="toggle_feedback_reason"
              phx-value-reason={reason}
              class={[
                "w-full rounded-lg border px-3 py-2 text-left font-mono text-[0.72rem] transition-all",
                if(reason in @feedback_reasons,
                  do: "border-[#03b6d4] bg-[#e8f7fb] text-[#03b6d4]",
                  else: "border-[#ece8e2] text-[#6a6761] hover:border-[#d8d3cc]"
                )
              ]}
            >
              {reason}
            </button>
          <% end %>
        </div>

        <div>
          <textarea
            phx-change="update_feedback_comment"
            name="comment"
            rows="3"
            placeholder="Add details (optional)…"
            class="w-full rounded-lg border border-[#ece8e2] px-3 py-2 font-mono text-[0.72rem] text-[#2c2b28] focus:border-[#03b6d4] focus:outline-none focus:ring-1 focus:ring-[#03b6d4]"
          ><%= @feedback_comment %></textarea>
        </div>
      </div>

      <div class="mt-4 flex items-center justify-end gap-2">
        <button
          type="button"
          phx-click="close_feedback_modal"
          class="rounded-lg border border-[#ece8e2] px-3 py-1.5 font-mono text-[0.72rem] text-[#6a6761] transition-colors hover:bg-[#f7f5f2]"
        >
          Cancel
        </button>
        <button
          type="button"
          phx-click="submit_feedback"
          class="rounded-lg bg-[#03b6d4] px-3 py-1.5 font-mono text-[0.72rem] text-white transition-colors hover:opacity-90"
        >
          Submit
        </button>
      </div>
    </div>
  </div>

  <div
    :if={@show_share_dialog}
    class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center z-50"
  >
    <div class="bg-white rounded-2xl shadow-2xl p-6 w-80 border border-black/10">
      <p class="font-mono text-sm font-bold text-[#2c3a50] mb-4">Share Conversation</p>
      <form phx-submit="share">
        <label class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider block mb-1.5">
          Permission
        </label>
        <select
          name="permission"
          class="font-mono text-[0.78rem] text-black w-full border border-black/10 rounded-lg px-2.5 py-1.5 bg-white focus:outline-none focus:ring-1 focus:ring-[#03b6d4] mb-5"
        >
          <option value="read">Read</option>
        </select>
        <div class="flex gap-2 justify-end">
          <button
            type="button"
            phx-click="close_share_dialog"
            class="font-mono text-[0.78rem] px-3 py-1.5 rounded-lg border border-black/10 text-black/60 hover:bg-black/5 transition-colors"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="font-mono text-[0.78rem] font-bold px-3 py-1.5 rounded-lg bg-[#03b6d4] text-white hover:bg-[#03b6d4]/90 transition-colors"
          >
            Create Link
          </button>
        </div>
      </form>
    </div>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
