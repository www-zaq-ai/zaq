<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title="AI Diagnostics"
  current_path={@current_path}
  features_version={@features_version}
>
  <!-- Metric Cards -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-black/10 p-5">
      <p class="font-mono text-[0.65rem] text-black/40 uppercase tracking-wider mb-1">
        LLM Model
      </p>
      <p class="font-mono text-sm font-bold text-black truncate">{@llm_config.model}</p>
    </div>
    <div class="bg-white rounded-xl border border-black/10 p-5">
      <p class="font-mono text-[0.65rem] text-black/40 uppercase tracking-wider mb-1">
        Embedding Model
      </p>
      <p class="font-mono text-sm font-bold text-black truncate">{@embedding_config.model}</p>
    </div>
    <div class="bg-white rounded-xl border border-black/10 p-5">
      <p class="font-mono text-[0.65rem] text-black/40 uppercase tracking-wider mb-1">
        PDF Pipeline Model
      </p>
      <p class="font-mono text-sm font-bold text-black truncate">{@image_to_text_config.model}</p>
    </div>
    <div class="bg-white rounded-xl border border-black/10 p-5">
      <p class="font-mono text-[0.65rem] text-black/40 uppercase tracking-wider mb-1">
        Knowledge Base
      </p>
      <p class="font-mono text-2xl font-bold text-black">
        {if @document_count, do: @document_count, else: "—"}
        <span class="font-mono text-[0.65rem] text-black/40 font-normal">docs</span>
      </p>
      <p class="font-mono text-sm font-bold text-black/60 mt-1">
        {if @chunk_count, do: @chunk_count, else: "—"}
        <span class="font-mono text-[0.65rem] text-black/40 font-normal">chunks</span>
      </p>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-6">
    <!-- LLM -->
    <ZaqWeb.Components.BOLayout.diagnostic_card
      label="LLM"
      status={@llm_status}
      event="test_llm"
    >
      <ZaqWeb.Components.BOLayout.config_row
        label="Endpoint"
        value={@llm_config.endpoint}
        truncate
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Model"
        value={@llm_config.model}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Temperature"
        value={to_string(@llm_config.temperature)}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Top-p"
        value={to_string(@llm_config.top_p)}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Logprobs"
        value={if @llm_config.supports_logprobs, do: "yes", else: "no"}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="JSON Mode"
        value={if @llm_config.supports_json_mode, do: "yes", else: "no"}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Max Context"
        value={"#{@llm_config.max_context_window} tokens"}
        hint="System Config → LLM"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Distance Threshold"
        value={to_string(@llm_config.distance_threshold)}
        hint="System Config → LLM"
      />
    </ZaqWeb.Components.BOLayout.diagnostic_card>
    
<!-- Embedding -->
    <ZaqWeb.Components.BOLayout.diagnostic_card
      label="Embedding"
      status={@embedding_status}
      event="test_embedding"
    >
      <div
        :if={not @embedding_ready}
        class="flex items-start gap-2 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mb-2"
      >
        <svg
          class="w-3.5 h-3.5 text-amber-500 mt-0.5 shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
          />
        </svg>
        <p class="font-mono text-[0.7rem] text-amber-700 leading-relaxed">
          Chunks table not created.
          <a href="/bo/system-config?tab=embedding" class="underline">
            Configure embedding settings →
          </a>
        </p>
      </div>
      <ZaqWeb.Components.BOLayout.config_row
        label="Endpoint"
        value={@embedding_config.endpoint}
        truncate
        hint="System Config → Embedding"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Model"
        value={@embedding_config.model}
        hint="System Config → Embedding"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Dimension"
        value={to_string(@embedding_config.dimension)}
        hint="System Config → Embedding"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Chunk Min Tokens"
        value={to_string(@embedding_config.chunk_min_tokens)}
        hint="System Config → Embedding"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Chunk Max Tokens"
        value={to_string(@embedding_config.chunk_max_tokens)}
        hint="System Config → Embedding"
      />
    </ZaqWeb.Components.BOLayout.diagnostic_card>
    
<!-- Image to Text -->
    <ZaqWeb.Components.BOLayout.diagnostic_card
      label="Image to Text"
      status={@image_to_text_status}
      event="test_image_to_text"
    >
      <ZaqWeb.Components.BOLayout.config_row
        label="Endpoint"
        value={@image_to_text_config.endpoint}
        truncate
        hint="System Config → Image to Text"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="Model"
        value={@image_to_text_config.model}
        hint="System Config → Image to Text"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="API Key"
        value={
          if @image_to_text_config.api_key_set,
            do: "configured",
            else: "not set — image steps skipped"
        }
        hint="System Config → Image to Text"
      />
      <ZaqWeb.Components.BOLayout.config_row
        label="PDF Python"
        value={
          case @pdf_pipeline_status do
            :idle -> "not tested"
            :loading -> "checking…"
            :ok -> "available"
            {:error, msg} -> msg
          end
        }
        hint="mix zaq.python.fetch"
      />
    </ZaqWeb.Components.BOLayout.diagnostic_card>
  </div>
  
<!-- Prompt Templates Summary -->
  <div class="mt-6">
    <div class="flex items-center justify-between mb-3">
      <p class="font-mono text-[0.7rem] text-black/40 uppercase tracking-wider">
        Prompt Templates
      </p>
      <.link
        href={~p"/bo/prompt-templates"}
        class="font-mono text-[0.75rem] text-[#03b6d4] hover:underline"
      >
        Manage →
      </.link>
    </div>

    <%= if @prompt_templates == [] do %>
      <div class="bg-white rounded-xl border border-dashed border-black/15 p-5 text-center">
        <p class="font-mono text-sm font-bold text-black mb-1">No Templates Found</p>
        <p class="font-mono text-[0.7rem] text-black/40 mb-3">
          Run seeds to insert the default retrieval, answering and chunk_title templates.
        </p>
        <code class="font-mono text-[0.7rem] bg-black/5 text-black/60 px-3 py-1.5 rounded-lg">
          mix run priv/repo/seeds.exs
        </code>
      </div>
    <% else %>
      <div class="grid grid-cols-3 gap-4">
        <div
          :for={tpl <- @prompt_templates}
          class="bg-white rounded-xl border border-black/10 p-5"
        >
          <div class="flex items-center justify-between mb-2">
            <p class="font-mono text-sm font-bold text-black">{tpl.slug}</p>
            <span
              :if={tpl.active}
              class="font-mono text-[0.7rem] px-2 py-0.5 rounded bg-emerald-100 text-emerald-700"
            >
              active
            </span>
            <span
              :if={!tpl.active}
              class="font-mono text-[0.7rem] px-2 py-0.5 rounded bg-black/5 text-black/30"
            >
              inactive
            </span>
          </div>
          <p class="font-mono text-[0.72rem] text-black/50 mb-3">{tpl.description}</p>
          <p class="font-mono text-[0.7rem] text-black/30">
            {tpl.body |> String.slice(0, 80)}{if String.length(tpl.body) > 80, do: "…", else: ""}
          </p>
        </div>
      </div>
    <% end %>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
