<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title="Agents"
  current_path={@current_path}
  features_version={@features_version}
>
  <div class="mx-auto max-w-[1500px] space-y-5">
    <section class="rounded-xl border border-[#e6e2db] bg-white px-5 py-4">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h1 class="font-mono text-[0.9rem] uppercase tracking-widest text-[#3e3b36]">
            AI Agents
          </h1>
          <p class="mt-1 font-mono text-[0.7rem] text-[#8e8a82]">
            Manage BO-defined agents and choose which ones can be selected in chat.
          </p>
        </div>
        <button
          id="new-agent-button"
          phx-click="new_agent"
          class="rounded-lg bg-[#03b6d4] px-3 py-2 font-mono text-[0.72rem] uppercase tracking-wider text-white hover:bg-[#0198b1] transition-colors"
        >
          New Agent
        </button>
      </div>

      <form
        id="agent-filters-form"
        phx-change="filter"
        class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-5"
      >
        <input
          type="text"
          name="filters[name]"
          value={@filters["name"]}
          placeholder="Filter by name"
          class="rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
        />
        <input
          type="text"
          name="filters[model]"
          value={@filters["model"]}
          placeholder="Filter by model"
          class="rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
        />
        <select
          name="filters[conversation_enabled]"
          class="rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
        >
          <option value="all" selected={@filters["conversation_enabled"] == "all"}>
            All conversation modes
          </option>
          <option value="enabled" selected={@filters["conversation_enabled"] == "enabled"}>
            Conversation enabled
          </option>
          <option value="disabled" selected={@filters["conversation_enabled"] == "disabled"}>
            Conversation disabled
          </option>
        </select>
        <select
          name="filters[active]"
          class="rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
        >
          <option value="all" selected={@filters["active"] == "all"}>All states</option>
          <option value="active" selected={@filters["active"] == "active"}>Active</option>
          <option value="inactive" selected={@filters["active"] == "inactive"}>Inactive</option>
        </select>
        <select
          name="filters[sovereign]"
          class="rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
        >
          <option value="all" selected={@filters["sovereign"] == "all"}>All sovereignty</option>
          <option value="sovereign" selected={@filters["sovereign"] == "sovereign"}>
            Sovereign
          </option>
          <option value="non_sovereign" selected={@filters["sovereign"] == "non_sovereign"}>
            Non-sovereign
          </option>
        </select>
      </form>
    </section>

    <ZaqWeb.Components.MasterDetailLayout.master_detail
      show_detail={@mode in [:new, :edit]}
      master_id="agents-master-pane"
      detail_id="agents-detail-pane"
    >
      <:master>
        <section class="rounded-xl border border-[#e6e2db] bg-white overflow-hidden">
          <div class="flex items-center justify-between border-b border-[#efece6] px-4 py-3">
            <h2 class="font-mono text-[0.72rem] uppercase tracking-widest text-[#7e7a73]">
              Agents ({@total_agents})
            </h2>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead class="bg-[#faf8f5]">
                <tr>
                  <th class="px-4 py-2 text-left font-mono text-[0.65rem] uppercase tracking-widest text-[#9d988f]">
                    Name
                  </th>
                  <th class="px-4 py-2 text-left font-mono text-[0.65rem] uppercase tracking-widest text-[#9d988f]">
                    Model
                  </th>
                  <th class="px-4 py-2 text-left font-mono text-[0.65rem] uppercase tracking-widest text-[#9d988f]">
                    Credential
                  </th>
                  <th class="px-4 py-2 text-left font-mono text-[0.65rem] uppercase tracking-widest text-[#9d988f]">
                    Conversation
                  </th>
                </tr>
              </thead>
              <tbody>
                <tr :if={@agents == []}>
                  <td
                    colspan="4"
                    class="px-4 py-8 text-center font-mono text-[0.7rem] text-[#a6a298]"
                  >
                    No agents found.
                  </td>
                </tr>
                <tr
                  :for={agent <- @agents}
                  id={"agent-row-#{agent.id}"}
                  phx-click="select_agent"
                  phx-value-id={agent.id}
                  class={[
                    "border-t border-[#f0ede8] cursor-pointer",
                    if(@selected_agent_id == agent.id,
                      do: "bg-[#f0f9fb]",
                      else: "hover:bg-[#faf8f5]"
                    )
                  ]}
                >
                  <td class="px-4 py-3">
                    <div class="text-left">
                      <p class="flex items-center gap-2 font-mono text-[0.75rem] text-[#3e3b36]">
                        <span class={[
                          "h-2 w-2 rounded-full",
                          if(agent.active, do: "bg-emerald-500", else: "bg-red-500")
                        ]} />
                        {agent.name}
                      </p>
                      <p class="mt-0.5 font-mono text-[0.65rem] text-[#9d988f] line-clamp-1">
                        {agent.description || "No description"}
                      </p>
                    </div>
                  </td>
                  <td class="px-4 py-3 font-mono text-[0.7rem] text-[#6e6a63]">{agent.model}</td>
                  <td class="px-4 py-3">
                    <div class="flex flex-col gap-1">
                      <span class="font-mono text-[0.68rem] text-[#6e6a63]">
                        {(agent.credential && agent.credential.provider) || "-"}
                      </span>
                      <span class={[
                        "inline-flex w-fit rounded-md px-2 py-1 font-mono text-[0.6rem] uppercase tracking-wider",
                        if(agent.credential && agent.credential.sovereign,
                          do: "bg-[#e6f4ff] text-[#2a74b8]",
                          else: "bg-[#f3f1ed] text-[#8d887f]"
                        )
                      ]}>
                        {if agent.credential && agent.credential.sovereign,
                          do: "Sovereign",
                          else: "Standard"}
                      </span>
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <span class={[
                      "rounded-md px-2 py-1 font-mono text-[0.62rem] uppercase tracking-wider",
                      if(agent.conversation_enabled,
                        do: "bg-[#e8f9fd] text-[#0290a8]",
                        else: "bg-[#f3f1ed] text-[#8d887f]"
                      )
                    ]}>
                      {if agent.conversation_enabled, do: "Enabled", else: "Disabled"}
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </:master>

      <:detail>
        <% selected_keys = @form[:enabled_tool_keys].value || [] %>
        <% unselected_tool_options =
          @tools
          |> Enum.reject(&(&1.key in selected_keys))
          |> Enum.map(&{"#{&1.label} (#{&1.key})", &1.key}) %>

        <section class="rounded-xl border border-[#e6e2db] bg-white p-4">
          <div class="flex items-center justify-between">
            <h2 class="font-mono text-[0.72rem] uppercase tracking-widest text-[#7e7a73]">
              {if @mode == :new, do: "Create Agent", else: "Edit Agent"}
            </h2>
            <button
              id="close-agent-detail"
              type="button"
              phx-click="cancel_agent_form"
              class="w-7 h-7 rounded-lg border border-black/15 text-black/40 hover:bg-black/5 flex items-center justify-center transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div
            :if={@form_notice}
            class="mt-3 rounded-lg border border-[#c8ebd6] bg-[#effcf4] px-3 py-2 font-mono text-[0.68rem] text-[#2e8a4f]"
          >
            {@form_notice}
          </div>

          <.form
            for={@form}
            id="configured-agent-form"
            phx-change="validate"
            phx-submit="save"
            class="mt-4 space-y-4"
          >
            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
              <div>
                <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                  Name
                </label>
                <input
                  type="text"
                  name="configured_agent[name]"
                  value={@form[:name].value}
                  class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
                />
                <p
                  :for={msg <- error_messages(@changeset, :name)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>
              <div>
                <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                  Strategy
                </label>
                <select
                  name="configured_agent[strategy]"
                  class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
                >
                  <option value="react" selected={@form[:strategy].value == "react"}>
                    react
                  </option>
                  <option value="cot" selected={@form[:strategy].value == "cot"}>cot</option>
                </select>
                <p
                  :for={msg <- error_messages(@changeset, :strategy)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>
            </div>

            <div>
              <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                Description
              </label>
              <input
                type="text"
                name="configured_agent[description]"
                value={@form[:description].value || ""}
                class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
              />
              <p
                :for={msg <- error_messages(@changeset, :description)}
                class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
              >
                {msg}
              </p>
            </div>

            <div>
              <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                Job Prompt
              </label>
              <textarea
                name="configured_agent[job]"
                rows="4"
                class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
              >{@form[:job].value}</textarea>
              <p
                :for={msg <- error_messages(@changeset, :job)}
                class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
              >
                {msg}
              </p>
            </div>

            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
              <div>
                <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                  Credential
                </label>
                <select
                  name="configured_agent[credential_id]"
                  class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
                >
                  <option value="">Select credential</option>
                  <option
                    :for={credential <- @credentials}
                    value={credential.id}
                    selected={to_string(@form[:credential_id].value) == to_string(credential.id)}
                  >
                    {credential.name} ({credential.provider})
                  </option>
                </select>
                <p
                  :for={msg <- error_messages(@changeset, :credential_id)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>
              <div>
                <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                  Model
                </label>
                <.searchable_select
                  :if={@model_options != []}
                  id="configured-agent-model-select"
                  name="configured_agent[model]"
                  value={@form[:model].value}
                  options={@model_options}
                  placeholder="Search models..."
                  empty_label="Select a model..."
                  compact={true}
                />
                <input
                  :if={@model_options == []}
                  type="text"
                  name="configured_agent[model]"
                  value={@form[:model].value || ""}
                  class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.72rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
                />
                <p
                  :for={msg <- error_messages(@changeset, :model)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between">
                <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82]">
                  Enabled Tools
                </label>
                <button
                  id="add-tools-button"
                  type="button"
                  phx-click="open_tools_picker"
                  class="font-mono text-[0.68rem] px-2.5 py-1 rounded-lg border border-[var(--zaq-color-accent)] zaq-text-accent hover:bg-[var(--zaq-color-accent-soft)] transition-colors"
                  disabled={
                    @selected_model_supports_tools == false or unselected_tool_options == []
                  }
                >
                  + Add tools
                </button>
              </div>
              <div
                :if={@selected_model_supports_tools == false}
                class="mb-2 rounded-lg border border-[#f3d9d5] bg-[#fff6f4] px-3 py-2 font-mono text-[0.64rem] text-[#a35246]"
              >
                Selected model does not support tool calling. Update the model before enabling tools.
              </div>
              <input type="hidden" name="configured_agent[enabled_tool_keys][]" value="" />
              <input
                :for={tool_key <- selected_keys}
                type="hidden"
                name="configured_agent[enabled_tool_keys][]"
                value={tool_key}
              />
              <div
                :if={@tools == []}
                class="rounded-lg border border-dashed border-[#e6e2db] px-3 py-2 font-mono text-[0.68rem] text-[#9a958c]"
              >
                No tools are currently registered in code.
              </div>
              <.selected_tools_panel
                :if={@tools != []}
                tools={@tools}
                selected_keys={selected_keys}
              />
              <p
                :for={msg <- error_messages(@changeset, :enabled_tool_keys)}
                class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
              >
                {msg}
              </p>
            </div>

            <div>
              <label class="block font-mono text-[0.65rem] uppercase tracking-widest text-[#8f8a82] mb-1">
                Advanced Options (JSON)
              </label>
              <textarea
                name="configured_agent[advanced_options_json]"
                rows="5"
                class="w-full rounded-lg border border-[#e6e2db] px-3 py-2 font-mono text-[0.7rem] text-[#3e3b36] outline-none focus:border-[#03b6d4] focus:ring-1 focus:ring-[#03b6d4]"
              >{@advanced_options_json}</textarea>
              <p
                :if={@advanced_options_error}
                class="mt-1 font-mono text-[0.64rem] text-[#af5a4b]"
              >
                {@advanced_options_error}
              </p>
              <p
                :for={msg <- error_messages(@changeset, :advanced_options)}
                class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
              >
                {msg}
              </p>
            </div>

            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              <div class="rounded-xl border border-[#efece6] bg-[#fafafa] px-3 py-2.5 flex items-center justify-between gap-3">
                <div>
                  <p class="font-mono text-[0.75rem] text-[#3e3b36]">Conversation enabled</p>
                  <p class="font-mono text-[0.64rem] text-[#8f8a82]">
                    Can be reached through conversation channels
                  </p>
                </div>
                <input
                  type="hidden"
                  name="configured_agent[conversation_enabled]"
                  value={
                    if @form[:conversation_enabled].value in [true, "true"],
                      do: "true",
                      else: "false"
                  }
                />
                <button
                  type="button"
                  phx-click="toggle_form_boolean"
                  phx-value-field="conversation_enabled"
                  class={[
                    "relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 focus:outline-none",
                    if(@form[:conversation_enabled].value in [true, "true"],
                      do: "bg-[var(--zaq-color-accent)]",
                      else: "bg-black/20"
                    )
                  ]}
                  role="switch"
                  aria-checked={to_string(@form[:conversation_enabled].value in [true, "true"])}
                >
                  <span class={[
                    "pointer-events-none inline-block h-4 w-4 rounded-full bg-white shadow transform transition-transform duration-200",
                    if(@form[:conversation_enabled].value in [true, "true"],
                      do: "translate-x-4",
                      else: "translate-x-0"
                    )
                  ]} />
                </button>
                <p
                  :for={msg <- error_messages(@changeset, :conversation_enabled)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>

              <div class="rounded-xl border border-[#efece6] bg-[#fafafa] px-3 py-2.5 flex items-center justify-between gap-3">
                <div>
                  <p class="font-mono text-[0.75rem] text-[#3e3b36]">Active</p>
                  <p class="font-mono text-[0.64rem] text-[#8f8a82]">
                    Agent can process requests
                  </p>
                </div>
                <input
                  type="hidden"
                  name="configured_agent[active]"
                  value={if @form[:active].value in [true, "true"], do: "true", else: "false"}
                />
                <button
                  type="button"
                  phx-click="toggle_form_boolean"
                  phx-value-field="active"
                  class={[
                    "relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 focus:outline-none",
                    if(@form[:active].value in [true, "true"],
                      do: "bg-[var(--zaq-color-accent)]",
                      else: "bg-black/20"
                    )
                  ]}
                  role="switch"
                  aria-checked={to_string(@form[:active].value in [true, "true"])}
                >
                  <span class={[
                    "pointer-events-none inline-block h-4 w-4 rounded-full bg-white shadow transform transition-transform duration-200",
                    if(@form[:active].value in [true, "true"],
                      do: "translate-x-4",
                      else: "translate-x-0"
                    )
                  ]} />
                </button>
                <p
                  :for={msg <- error_messages(@changeset, :active)}
                  class="mt-1 font-mono text-[0.64rem] text-[#a35246]"
                >
                  {msg}
                </p>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <button
                id="save-agent-button"
                type="submit"
                class="rounded-lg bg-[#03b6d4] px-4 py-2 font-mono text-[0.72rem] uppercase tracking-wider text-white hover:bg-[#0198b1] transition-colors"
              >
                {if @mode == :new, do: "Create Agent", else: "Save Agent"}
              </button>
              <button
                :if={@mode == :edit and is_integer(@selected_agent_id)}
                id="delete-agent-button"
                type="button"
                phx-click="delete_agent"
                phx-value-id={@selected_agent_id}
                class="rounded-lg border border-red-200 bg-red-50 px-4 py-2 font-mono text-[0.72rem] uppercase tracking-wider text-red-700 hover:bg-red-100 transition-colors"
              >
                Delete Agent
              </button>
            </div>
          </.form>
        </section>

        <ZaqWeb.Components.BOModal.modal_shell
          :if={@tools_picker_open}
          id="agent-tools-picker-modal"
          cancel_event="close_tools_picker"
          max_width_class="max-w-lg"
          panel_class="p-6"
        >
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-mono text-[0.78rem] uppercase tracking-widest text-[#7e7a73]">
              Add tools
            </h3>
            <button
              type="button"
              phx-click="close_tools_picker"
              class="w-7 h-7 rounded-lg border border-black/15 text-black/40 hover:bg-black/5 flex items-center justify-center transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <form phx-change="add_tool_from_picker">
            <.searchable_select
              id="agent-tools-picker-select"
              name="tool_key"
              value={@tools_picker_value}
              options={unselected_tool_options}
              placeholder="Search by tool name..."
              empty_label="Choose a tool to add..."
              compact={true}
            />
          </form>

          <div class="mt-4">
            <p class="mb-2 font-mono text-[0.68rem] uppercase tracking-wider text-[#8f8a82]">
              Enabled tools
            </p>
            <.selected_tools_panel tools={@tools} selected_keys={selected_keys} />
          </div>

          <p class="mt-3 font-mono text-[0.64rem] text-[#8f8a82]">
            Pick one tool at a time. This modal stays open to add multiple tools quickly.
          </p>
        </ZaqWeb.Components.BOModal.modal_shell>
      </:detail>
    </ZaqWeb.Components.MasterDetailLayout.master_detail>
  </div>
</ZaqWeb.Components.BOLayout.bo_layout>
