<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title="Skills"
  current_path={@current_path}
  features_version={@features_version}
>
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="zaq-text-h2" style="color: var(--zaq-text-color-body-default)">Agent Skills</p>
      <p class="zaq-text-body-sm" style="color: var(--zaq-text-color-body-tertiary)">
        Reusable instruction + tool bundles attachable to any agent
      </p>
    </div>
    <button
      id="new-skill-button"
      type="button"
      phx-click="new_skill"
      class="zaq-btn zaq-btn-primary"
    >
      + New skill
    </button>
  </div>
  
<!-- Filters -->
  <form id="skills-filter-form" phx-change="filter" class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <label class="zaq-field-label-uppercase block mb-1.5">
        Search
      </label>
      <input
        type="text"
        name="filters[q]"
        value={@filters["q"]}
        placeholder="Name or description..."
        phx-debounce="300"
        class="w-full zaq-control-text"
      />
    </div>
    <div>
      <label class="zaq-field-label-uppercase block mb-1.5">
        Tags
      </label>
      <input
        type="text"
        name="filters[tag]"
        value={@filters["tag"]}
        placeholder="Comma-separated tags, matches any..."
        phx-debounce="300"
        class="w-full zaq-control-text"
      />
    </div>
  </form>
  
<!-- Skill list + form (master/detail) -->
  <ZaqWeb.Components.MasterDetailLayout.master_detail
    show_detail={@mode != :idle}
    master_id="skills-master-pane"
    detail_id="skills-detail-pane"
  >
    <:master>
      <DSTable.table id="skills-table" scrollable>
        <:caption>Skills ({length(@skills)})</:caption>
        <:head>
          <DSTable.table_head_row>
            <DSTable.table_cell element={:th}>Name</DSTable.table_cell>
            <DSTable.table_cell element={:th}>Tags</DSTable.table_cell>
            <DSTable.table_cell element={:th}>Tools</DSTable.table_cell>
            <DSTable.table_cell element={:th}>Status</DSTable.table_cell>
            <DSTable.table_cell element={:th} />
          </DSTable.table_head_row>
        </:head>
        <:body>
          <DSTable.table_empty :if={@skills == []} colspan={5}>
            No skills found.
          </DSTable.table_empty>
          <DSTable.table_row
            :for={skill <- @skills}
            id={"skill-row-#{skill.id}"}
            variant={
              if(@selected_skill != nil and @selected_skill.id == skill.id,
                do: :selected,
                else: :default
              )
            }
            click="select_skill"
            click_values={%{id: skill.id}}
          >
            <DSTable.table_cell>
              <p
                class="zaq-text-body-sm truncate"
                style="color: var(--zaq-text-color-body-default)"
              >
                {skill.name}
              </p>
              <p
                :if={skill.description}
                class="zaq-text-caption truncate"
                style="color: var(--zaq-text-color-body-tertiary)"
              >
                {skill.description}
              </p>
            </DSTable.table_cell>
            <DSTable.table_cell>
              <span
                :for={tag <- skill.tags}
                class="zaq-pill zaq-text-caption zaq-pill--elevated mr-1"
              >
                {tag}
              </span>
            </DSTable.table_cell>
            <DSTable.table_cell>
              <span class="zaq-text-body-sm" style="color: var(--zaq-text-color-body-secondary)">
                {length(skill.tool_keys)}
              </span>
            </DSTable.table_cell>
            <DSTable.table_cell>
              <span class={[
                "zaq-pill zaq-text-caption",
                if(skill.active, do: "zaq-pill--success", else: "zaq-pill--elevated")
              ]}>
                {if skill.active, do: "active", else: "inactive"}
              </span>
            </DSTable.table_cell>
            <DSTable.table_cell align={:right}>
              <DSTable.table_actions>
                <button
                  id={"delete-skill-#{skill.id}"}
                  type="button"
                  phx-click="delete_skill"
                  phx-value-id={skill.id}
                  data-confirm="Delete this skill? Agents using it will lose its tools and instructions."
                  class="zaq-text-caption transition-colors"
                  style="color: var(--zaq-text-color-body-danger)"
                >
                  Delete
                </button>
              </DSTable.table_actions>
            </DSTable.table_cell>
          </DSTable.table_row>
        </:body>
      </DSTable.table>
    </:master>

    <:detail>
      <!-- Skill form -->
      <div class="zaq-card-default">
        <p class="zaq-text-h4 mb-4" style="color: var(--zaq-text-color-body-default)">
          {if @mode == :new, do: "New Skill", else: "Edit Skill"}
        </p>
        
<!-- Tools + MCP endpoints (assigns-backed, injected into attrs on save) -->
        <% unselected_tool_options =
          @tools
          |> Enum.reject(&(&1.key in @form_tool_keys))
          |> Enum.map(&{"#{&1.label} (#{&1.key})", &1.key}) %>
        <% unselected_mcp_options =
          @mcp_endpoints
          |> Enum.reject(&(&1.id in @form_mcp_endpoint_ids))
          |> Enum.map(&{"#{&1.name} (##{&1.id})", &1.id}) %>

        <.form
          for={@form}
          id="skill-form"
          phx-change="validate"
          phx-submit="save"
          class="space-y-5"
        >
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="zaq-field-label-uppercase block mb-1.5">
                Name
              </label>
              <input
                type="text"
                name="skill[name]"
                value={@form[:name].value}
                placeholder="lowercase-kebab-case"
                class="w-full zaq-control-text"
              />
              <p
                :for={error <- field_errors(@form[:name])}
                class="zaq-field-error mt-1"
              >
                {error}
              </p>
            </div>
            <div>
              <label class="zaq-field-label-uppercase block mb-1.5">
                Tags
              </label>
              <input
                type="text"
                name="skill[tags]"
                value={tags_to_string(@form[:tags].value)}
                placeholder="math, utility"
                class="w-full zaq-control-text"
              />
            </div>
          </div>

          <div>
            <label class="zaq-field-label-uppercase block mb-1.5">
              Description
            </label>
            <input
              type="text"
              name="skill[description]"
              value={@form[:description].value}
              class="w-full zaq-control-text"
            />
            <p
              :for={error <- field_errors(@form[:description])}
              class="zaq-field-error mt-1"
            >
              {error}
            </p>
          </div>
          
<!-- Tools + MCP endpoints (assigns-backed, injected into attrs on save) -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="mb-2 flex items-center justify-between">
                <label class="zaq-field-label-uppercase block">
                  Tools
                </label>
                <button
                  id="add-tools-button"
                  type="button"
                  phx-click="open_tools_picker"
                  class="zaq-btn zaq-btn-secondary"
                  disabled={@tools == [] or unselected_tool_options == []}
                >
                  + Add tools
                </button>
              </div>
              <div
                :if={@tools == []}
                class="rounded-lg border border-dashed px-3 py-2 zaq-text-caption"
                style="border-color: var(--zaq-border-color-default); color: var(--zaq-text-color-body-tertiary)"
              >
                No tools are currently registered in code.
              </div>
              <.selected_tools_panel
                :if={@tools != []}
                tools={@tools}
                selected_keys={@form_tool_keys}
              />
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between">
                <label class="zaq-field-label-uppercase block">
                  MCP Endpoints
                </label>
                <button
                  id="add-mcp-button"
                  type="button"
                  phx-click="open_mcp_picker"
                  class="zaq-btn zaq-btn-secondary"
                  disabled={unselected_mcp_options == []}
                >
                  + Add MCP
                </button>
              </div>
              <div
                :if={@mcp_endpoints == []}
                class="rounded-lg border border-dashed px-3 py-2 zaq-text-caption"
                style="border-color: var(--zaq-border-color-default); color: var(--zaq-text-color-body-tertiary)"
              >
                No MCP endpoints are configured. Add one in System Config.
              </div>
              <.selected_mcp_panel
                :if={@mcp_endpoints != []}
                mcp_endpoints={@mcp_endpoints}
                selected_endpoint_ids={@form_mcp_endpoint_ids}
              />
            </div>
          </div>

          <div>
            <label class="zaq-field-label-uppercase block mb-1.5">
              Instructions
            </label>
            <.markdown_editor
              id="skill-body-input"
              field={@form[:body]}
              preview={@body_preview}
              toggle_event="toggle_body_preview"
              rows={10}
              placeholder="Markdown instructions injected into the agent's system prompt..."
            />
            <p
              :for={error <- field_errors(@form[:body])}
              class="zaq-field-error mt-1"
            >
              {error}
            </p>
          </div>
          
<!-- Active -->
          <label
            class="flex items-center gap-2 zaq-text-body-sm"
            style="color: var(--zaq-text-color-body-secondary)"
          >
            <input type="hidden" name="skill[active]" value="false" />
            <input
              type="checkbox"
              name="skill[active]"
              value="true"
              checked={@form[:active].value in [true, "true"]}
              class="zaq-bo-checkbox"
            /> Active
          </label>
          
<!-- Actions -->
          <div class="flex items-center justify-end gap-3 pt-2">
            <button
              type="button"
              phx-click="cancel_form"
              class="zaq-btn zaq-btn-secondary"
            >
              Cancel
            </button>
            <button
              id="save-skill-button"
              type="submit"
              class="zaq-btn zaq-btn-secondary"
            >
              Save
            </button>
          </div>
        </.form>

        <ZaqWeb.Components.BOModal.modal_shell
          :if={@tools_picker_open}
          id="skill-tools-picker-modal"
          cancel_event="close_tools_picker"
          max_width_class="max-w-lg"
          panel_class="p-6"
        >
          <div class="flex items-center justify-between mb-4">
            <h3
              class="zaq-text-h5 uppercase tracking-widest"
              style="color: var(--zaq-text-color-body-tertiary)"
            >
              Add tools
            </h3>
            <button
              type="button"
              phx-click="close_tools_picker"
              aria-label="Close"
              class="zaq-btn zaq-btn-icon zaq-btn-secondary"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <form phx-change="add_tool_from_picker">
            <.searchable_select
              id="skill-tools-picker-select"
              name="tool_key"
              value={@tools_picker_value}
              options={unselected_tool_options}
              placeholder="Search by tool name..."
              empty_label="Choose a tool to add..."
              compact={true}
            />
          </form>

          <div class="mt-4">
            <p
              class="mb-2 uppercase tracking-wider zaq-text-caption"
              style="color: var(--zaq-text-color-body-tertiary)"
            >
              Enabled tools
            </p>
            <.selected_tools_panel tools={@tools} selected_keys={@form_tool_keys} />
          </div>

          <p class="mt-3 zaq-text-caption" style="color: var(--zaq-text-color-body-tertiary)">
            Pick one tool at a time. This modal stays open to add multiple tools quickly.
          </p>
        </ZaqWeb.Components.BOModal.modal_shell>

        <ZaqWeb.Components.BOModal.modal_shell
          :if={@mcp_picker_open}
          id="skill-mcp-picker-modal"
          cancel_event="close_mcp_picker"
          max_width_class="max-w-lg"
          panel_class="p-6"
        >
          <div class="flex items-center justify-between mb-4">
            <h3
              class="zaq-text-h5 uppercase tracking-widest"
              style="color: var(--zaq-text-color-body-tertiary)"
            >
              Add MCP endpoints
            </h3>
            <button
              type="button"
              phx-click="close_mcp_picker"
              aria-label="Close"
              class="zaq-btn zaq-btn-icon zaq-btn-secondary"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <form phx-change="add_mcp_from_picker">
            <.searchable_select
              id="skill-mcp-picker-select"
              name="endpoint_id"
              value={@mcp_picker_value}
              options={unselected_mcp_options}
              placeholder="Search by endpoint name..."
              empty_label="Choose an MCP endpoint to add..."
              compact={true}
            />
          </form>

          <div class="mt-4">
            <p
              class="mb-2 uppercase tracking-wider zaq-text-caption"
              style="color: var(--zaq-text-color-body-tertiary)"
            >
              Attached MCP endpoints
            </p>
            <.selected_mcp_panel
              mcp_endpoints={@mcp_endpoints}
              selected_endpoint_ids={@form_mcp_endpoint_ids}
            />
          </div>

          <p class="mt-3 zaq-text-caption" style="color: var(--zaq-text-color-body-tertiary)">
            Pick one endpoint at a time. This modal stays open to add multiple endpoints quickly.
          </p>
        </ZaqWeb.Components.BOModal.modal_shell>
      </div>
    </:detail>
  </ZaqWeb.Components.MasterDetailLayout.master_detail>
</ZaqWeb.Components.BOLayout.bo_layout>
