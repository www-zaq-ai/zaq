<ZaqWeb.Components.BOLayout.bo_layout
  current_user={@current_user}
  flash={@flash}
  page_title={@page_title}
  current_path={@current_path}
>
  <div id="oauth-popup-listener" phx-hook="OAuthPopupListener"></div>

  <div class="flex gap-6 items-start">
    <%!-- Sidebar --%>
    <div class="w-52 shrink-0">
      <div class="bg-white rounded-2xl border border-black/[0.06] shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-black/[0.06] bg-[#fafafa]">
          <p class="font-mono text-[0.7rem] font-semibold text-black/40 uppercase tracking-wider">
            Configuration
          </p>
        </div>
        <nav class="p-2 space-y-0.5">
          <button
            phx-click="switch_tab"
            phx-value-tab="ai_credentials"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :ai_credentials,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            AI Credentials
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="auth_credentials"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :auth_credentials,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            Auth Credentials
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="mcps"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :mcps,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            MCPs
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="global"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :global,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            Global
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="llm"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :llm,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            LLM
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="embedding"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :embedding,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            Embedding
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="image_to_text"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :image_to_text,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            Image To Text
          </button>
          <button
            phx-click="switch_tab"
            phx-value-tab="telemetry"
            class={[
              "w-full text-left px-3 py-2.5 rounded-xl font-mono text-[0.82rem] transition-all",
              if(@active_tab == :telemetry,
                do: "bg-[#03b6d4]/10 text-[#03b6d4] font-semibold",
                else: "text-black/60 hover:bg-black/[0.04] hover:text-black"
              )
            ]}
          >
            Telemetry
          </button>
        </nav>
      </div>
    </div>

    <%!-- Content --%>
    <div class="flex-1 min-w-0">
      <ZaqWeb.Live.BO.System.SystemConfig.AICredentialsTab.panel
        :if={@active_tab == :ai_credentials}
        credentials={@ai_credentials}
        ai_grants={@ai_grants}
        form={@ai_credential_form}
        modal={@ai_credential_modal}
        delete_confirm_modal={@ai_credential_delete_confirm_modal}
        action={@ai_credential_action}
        credential_id={@ai_credential_id}
        provider_options={@ai_provider_options}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.ConnectCredentialsTab.panel
        :if={@active_tab == :auth_credentials}
        credentials={@connect_credentials}
        grants_modal={@connect_grants_modal}
        selected_credential={@selected_connect_credential}
        selected_grants={@selected_connect_grants}
        selected_connect_refresh_schedule={@selected_connect_refresh_schedule}
        credential_modal={@connect_credential_modal}
        credential_form={@connect_credential_form}
        credential_changeset={@connect_credential_changeset}
        credential_errors={@connect_credential_errors}
        connect_default_scopes_text={@connect_default_scopes_text}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.MCPTab.panel
        :if={@active_tab == :mcps}
        entries={@mcp_endpoints}
        total_count={@mcp_total_count}
        page={@mcp_page}
        per_page={@mcp_per_page}
        filter_name={@mcp_filter_name}
        filter_type={@mcp_filter_type}
        filter_status={@mcp_filter_status}
        form={@mcp_endpoint_form}
        rows={@mcp_endpoint_rows}
        modal={@mcp_endpoint_modal}
        action={@mcp_endpoint_action}
        delete_confirm_modal={@mcp_endpoint_delete_confirm_modal}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.GlobalTab.panel
        :if={@active_tab == :global}
        global_agent_options={@global_agent_options}
        global_default_agent_id={@global_default_agent_id}
        global_base_url={@global_base_url}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.LLMTab.panel
        :if={@active_tab == :llm}
        form={@llm_form}
        credential_options={@llm_credential_options}
        model_options={@llm_model_options}
        capabilities={@llm_capabilities}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.EmbeddingTab.panel
        :if={@active_tab == :embedding}
        form={@embedding_form}
        credential_options={@embedding_credential_options}
        model_options={@embedding_model_options}
        locked={@embedding_locked}
        unlock_modal={@embedding_unlock_modal}
        model_changed={@model_changed}
        save_confirm_modal={@embedding_save_confirm_modal}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.ImageToTextTab.panel
        :if={@active_tab == :image_to_text}
        form={@image_to_text_form}
        credential_options={@image_to_text_credential_options}
        model_options={@image_to_text_model_options}
      />
      <ZaqWeb.Live.BO.System.SystemConfig.TelemetryTab.panel
        :if={@active_tab == :telemetry}
        form={@telemetry_form}
      />
    </div>
  </div>

  <ZaqWeb.Components.BOModal.modal_shell
    :if={@oauth_claim_modal}
    id="oauth-claim-modal"
    cancel_event="close_oauth_claim"
    max_width_class="max-w-md"
  >
    <div class="text-center">
      <div class="mx-auto mb-4 grid h-10 w-10 place-items-center rounded-lg bg-[#03b6d4]/10 text-[#03b6d4]">
        <.icon name="hero-arrow-top-right-on-square" class="h-5 w-5" />
      </div>
      <h3 class="mb-2 font-mono text-base font-bold text-black">
        OAuth authorization in progress
      </h3>
      <p class="mb-6 font-mono text-[0.75rem] text-black/40">
        Complete the provider authorization in the popup window. This dialog updates automatically when finished.
      </p>
      <button
        type="button"
        phx-click="close_oauth_claim"
        class="rounded-xl border border-black/10 px-5 py-2.5 font-mono text-[0.75rem] text-black/40 transition-all hover:border-black/20 hover:text-black"
      >
        Cancel
      </button>
    </div>
  </ZaqWeb.Components.BOModal.modal_shell>
</ZaqWeb.Components.BOLayout.bo_layout>
